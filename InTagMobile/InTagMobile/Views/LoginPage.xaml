<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InTagMobile.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A365D">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
                <Label Text="InTag" FontSize="42" FontAttributes="Bold"
                       HorizontalTextAlignment="Center" TextColor="White" />
                <Label Text="Asset Tracking" FontSize="18"
                       HorizontalTextAlignment="Center" TextColor="#8BADD6" />
                <BoxView HeightRequest="1" Color="#2D5A8E" Margin="0,10" />
                <Frame BackgroundColor="White" CornerRadius="12" Padding="20" HasShadow="True">
                    <VerticalStackLayout Spacing="15">
                        <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" />
                        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" />
                        <Label x:Name="ErrorLabel" TextColor="Red" FontSize="12" />
                        <Button x:Name="LoginBtn" Text="Sign In"
                                Clicked="OnLoginClicked"
                                BackgroundColor="#1A365D" TextColor="White"
                                CornerRadius="8" HeightRequest="48" />
                        <ActivityIndicator x:Name="LoadingIndicator"
                                           IsRunning="False" IsVisible="False"
                                           Color="#1A365D" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>
