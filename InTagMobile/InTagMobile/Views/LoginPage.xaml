<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InTagMobile.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FBE8CE">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="30" VerticalOptions="Center">

            <!-- Header -->
            <VerticalStackLayout Spacing="5">
                <Image Source="loginlogo.png"
                       HeightRequest="100"
                       Aspect="AspectFit"
                       HorizontalOptions="Center" />
          
                <Label Text="Asset Tracking System"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="#6B7280" />
            </VerticalStackLayout>

            <!-- Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="20"
                   Padding="20"
                   HasShadow="True">

                <VerticalStackLayout Spacing="18">

                    <!-- Email -->
                    <Frame Padding="10"
                           CornerRadius="12"
                           BackgroundColor="#F9FAFB"
                           HasShadow="False">

                        <Entry x:Name="EmailEntry"
                               Placeholder="Email Address"
                               Keyboard="Email"
                               TextColor="Black"
                               PlaceholderColor="#9CA3AF" />
                    </Frame>

                    <!-- Password -->
                    <Frame Padding="10"
                           CornerRadius="12"
                           BackgroundColor="#F9FAFB"
                           HasShadow="False">

                        <Entry x:Name="PasswordEntry"
                               Placeholder="Password"
                               IsPassword="True"
                               TextColor="Black"
                               PlaceholderColor="#9CA3AF" />
                    </Frame>

                    <!-- Error -->
                    <Label x:Name="ErrorLabel"
                           TextColor="#EF4444"
                           FontSize="12"
                           IsVisible="False" />

                    <!-- Button -->
                    <Button x:Name="LoginBtn"
                            Text="Sign In"
                            Clicked="OnLoginClicked"
                            BackgroundColor="#1A365D"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"
                            FontAttributes="Bold" />

                    <!-- Loading -->
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="#1A365D" />

                </VerticalStackLayout>
            </Frame>

            <!-- Footer -->
            <Label Text="Secure Login • Powered by IdenTech"
                   FontSize="12"
                   HorizontalTextAlignment="Center"
                   TextColor="#9CA3AF" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
