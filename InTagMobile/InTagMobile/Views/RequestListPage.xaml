<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:InTagMobile.Models"
             x:Class="InTagMobile.Views.RequestListPage"
             Title="Tracking Requests">
    <ContentPage.Content>
        <Grid RowDefinitions="*">
            <CollectionView x:Name="RequestList" SelectionMode="Single"
                            SelectionChanged="OnRequestSelected">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                        <Label Text="No tracking requests" FontSize="18"
                               TextColor="Gray" HorizontalTextAlignment="Center" />
                        <Label Text="Create a request from the web portal" FontSize="14"
                               TextColor="LightGray" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TrackingRequestDto">
                        <Frame Margin="10,5" Padding="15" CornerRadius="8"
                               HasShadow="True" BackgroundColor="White">
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding RequestNumber}" FontAttributes="Bold"
                                           FontSize="16" TextColor="#1A365D" />
                                    <Frame BackgroundColor="#2D5A8E" CornerRadius="4"
                                           Padding="6,2" HasShadow="False" VerticalOptions="Center">
                                        <Label Text="{Binding StatusDisplay}" FontSize="11" TextColor="White" />
                                    </Frame>
                                </HorizontalStackLayout>
                                <Label Text="{Binding Title}" FontSize="14" TextColor="Gray" />
                                <HorizontalStackLayout Spacing="10" Margin="0,4,0,0">
                                    <Label Text="{Binding LocationName}" FontSize="12" TextColor="#666" />
                                    <Label Text="{Binding ScannedCount, StringFormat='{0} scanned'}"
                                           FontSize="12" TextColor="#666" />
                                    <Label Text="{Binding TotalAssets, StringFormat='of {0}'}"
                                           FontSize="12" TextColor="#666" />
                                </HorizontalStackLayout>
                                <ProgressBar Progress="{Binding ProgressPercent, Converter={StaticResource PercentToProgressConverter}}"
                                             ProgressColor="#1A365D" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage.Content>
</ContentPage>
