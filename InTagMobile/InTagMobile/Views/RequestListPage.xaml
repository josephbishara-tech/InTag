<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:InTagMobile.Models"
             x:Class="InTagMobile.Views.RequestListPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F4F6FA">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid BackgroundColor="#1A365D" Padding="20,40,20,15">
            <VerticalStackLayout Spacing="5">
                <Label Text="Tracking Requests"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White" />

                <Label Text="Monitor and manage asset tracking"
                       FontSize="13"
                       TextColor="#D1D5DB" />
            </VerticalStackLayout>
        </Grid>

        <!-- Content -->
        <RefreshView Grid.Row="1"
                     x:Name="RefreshContainer"
                     Refreshing="OnRefreshing">

            <CollectionView x:Name="RequestList"
                            SelectionMode="None"
                            Margin="10">

                <!-- Empty View -->
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10">

                        <Label Text="📭"
                               FontSize="50"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="No tracking requests"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#374151"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Create a request from the web portal"
                               FontSize="13"
                               TextColor="#9CA3AF"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <!-- Items -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TrackingRequestDto">

                        <Frame Margin="0,6"
                               Padding="15"
                               CornerRadius="18"
                               HasShadow="True"
                               BackgroundColor="White">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRequestTapped"
                                                      CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="12">

                                <!-- Top -->
                                <Grid ColumnDefinitions="*,Auto">

                                    <Label Text="{Binding RequestNumber}"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           TextColor="#1A365D" />

                                    <!-- Status -->
                                    <Frame Grid.Column="1"
                                           BackgroundColor="{Binding StatusDisplay, Converter={StaticResource StatusColorConverter}}"
                                           CornerRadius="12"
                                           Padding="10,4"
                                           HasShadow="False">

                                        <Label Text="{Binding StatusDisplay}"
                                               FontSize="11"
                                               TextColor="White"
                                               FontAttributes="Bold"/>
                                    </Frame>

                                </Grid>

                                <!-- Title -->
                                <Label Text="{Binding Title}"
                                       FontSize="14"
                                       TextColor="#4B5563"
                                       LineBreakMode="TailTruncation" />

                                <!-- Info -->
                                <Grid ColumnDefinitions="*,Auto">

                                    <!-- Location -->
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="📍" FontSize="12"/>
                                        <Label Text="{Binding LocationName}"
                                               FontSize="12"
                                               TextColor="#6B7280" />
                                    </HorizontalStackLayout>

                                    <!-- Count -->
                                    <HorizontalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="📦" FontSize="12"/>
                                        <Label FontSize="12" TextColor="#6B7280">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding ScannedCount}" FontAttributes="Bold"/>
                                                    <Span Text=" / "/>
                                                    <Span Text="{Binding TotalAssets}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </HorizontalStackLayout>

                                </Grid>

                                <!-- Progress -->
                                <Grid RowDefinitions="Auto,Auto">

                                    <ProgressBar Grid.Row="0"
                                                 Progress="{Binding ProgressPercent, Converter={StaticResource PercentToProgressConverter}}"
                                                 ProgressColor="#1A365D"
                                                 BackgroundColor="#E5E7EB"
                                                 HeightRequest="6"/>

                                    <Label Grid.Row="1"
                                           Text="{Binding ProgressPercent, StringFormat='{0:N0}% completed'}"
                                           FontSize="11"
                                           TextColor="#9CA3AF"
                                           HorizontalOptions="End"/>

                                </Grid>

                            </VerticalStackLayout>
                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </RefreshView>

    </Grid>
</ContentPage>
