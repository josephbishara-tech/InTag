<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:InTagMobile.Models"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="InTagMobile.Views.TrackingSessionPage"
             Title="Scanning">
    <ContentPage.Content>
        <Grid RowDefinitions="Auto,300,Auto,*,Auto">

            <Frame Grid.Row="0" BackgroundColor="#1A365D" CornerRadius="0"
                   Padding="15" HasShadow="False">
                <Grid ColumnDefinitions="*,*,*">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label x:Name="ScannedLabel" Text="0" FontSize="24"
                               FontAttributes="Bold" TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Scanned" FontSize="11" TextColor="#8BADD6"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                        <Label x:Name="PendingLabel" Text="0" FontSize="24"
                               FontAttributes="Bold" TextColor="#FFD700"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Pending" FontSize="11" TextColor="#8BADD6"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                        <Label x:Name="ProgressLabel" Text="0%" FontSize="24"
                               FontAttributes="Bold" TextColor="#00FF88"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Progress" FontSize="11" TextColor="#8BADD6"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <zxing:CameraBarcodeReaderView Grid.Row="1"
                x:Name="BarcodeReader"
                BarcodesDetected="OnBarcodesDetected" />

            <Frame Grid.Row="2" Margin="10,5" Padding="10" CornerRadius="8"
                   BackgroundColor="#F0F8FF" HasShadow="False">
                <Label x:Name="LastScanLabel" Text="Point camera at asset QR/barcode"
                       FontSize="14" HorizontalTextAlignment="Center" />
            </Frame>

            <CollectionView Grid.Row="3" x:Name="PendingList" Margin="10,0">
                <CollectionView.Header>
                    <Label Text="Pending Assets" FontAttributes="Bold" FontSize="14" Margin="0,5" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TrackingLineDto">
                        <Grid ColumnDefinitions="*,Auto" Padding="10,8">
                            <VerticalStackLayout>
                                <Label Text="{Binding AssetCode}" FontAttributes="Bold"
                                       FontSize="14" TextColor="#1A365D" />
                                <Label Text="{Binding AssetName}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="⏳" FontSize="20" VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="4" ColumnDefinitions="*,*" Padding="10" ColumnSpacing="10">
                <Button Text="Toggle Scanner" Clicked="OnToggleScanner"
                        BackgroundColor="#2D5A8E" TextColor="White" CornerRadius="8" />
                <Button Grid.Column="1" Text="Complete" Clicked="OnCompleteClicked"
                        BackgroundColor="#28A745" TextColor="White" CornerRadius="8" />
            </Grid>
        </Grid>
    </ContentPage.Content>
</ContentPage>
