@model IReadOnlyList<InTagViewModelLayer.Maintenance.MTBFMTTRResultVm>

<div class="content-header"><h1><i class="bi bi-heart-pulse me-2"></i>Asset Reliability — MTBF / MTTR</h1></div>

@if (!Model.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-1"></i>No failure data recorded yet. Reliability metrics require corrective work orders with failure logs.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light"><tr><th>Asset</th><th class="text-end">Failures</th><th class="text-end">MTBF (hrs)</th><th class="text-end">MTTR (hrs)</th><th class="text-end">Downtime (hrs)</th><th>Availability</th></tr></thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var avColor = r.Availability >= 95 ? "bg-success" : r.Availability >= 85 ? "bg-warning" : "bg-danger";
                        <tr>
                            <td>
                                <a asp-controller="Asset" asp-action="Details" asp-route-id="@r.AssetId" class="text-decoration-none fw-bold">@r.AssetCode</a>
                                <br /><small class="text-muted">@r.AssetName</small>
                            </td>
                            <td class="text-end">@r.FailureCount</td>
                            <td class="text-end fw-bold">@r.MTBF.ToString("N0")</td>
                            <td class="text-end">@r.MTTR.ToString("N1")</td>
                            <td class="text-end text-danger">@r.TotalDowntimeHours.ToString("N1")</td>
                            <td style="width:180px;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:8px;"><div class="progress-bar @avColor" style="width:@r.Availability%"></div></div>
                                    <strong class="@(r.Availability < 85 ? "text-danger" : "")">@r.Availability%</strong>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
