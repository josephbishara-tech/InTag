@model IReadOnlyList<InTagViewModelLayer.Maintenance.PMScheduleListItemVm>

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-calendar-check me-2"></i>PM Schedules</h1>
    <div class="d-flex gap-2">
        <form asp-action="GenerateWorkOrders" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary btn-sm" onclick="return confirm('Generate work orders for all due PM schedules?')"><i class="bi bi-play-fill me-1"></i>Generate Due WOs</button>
        </form>
        <a asp-action="Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>New Schedule</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Name</th><th>Asset</th><th>Trigger</th><th>Frequency</th><th>Next Due</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No PM schedules. <a asp-action="Create">Create one</a>.</td></tr>
                }
                @foreach (var pm in Model)
                {
                    <tr class="@(pm.IsOverdue ? "table-warning" : "")">
                        <td><a asp-action="Details" asp-route-id="@pm.Id" class="fw-bold text-decoration-none">@pm.Name</a></td>
                        <td><small>@pm.AssetCode</small><br /><small class="text-muted">@pm.AssetName</small></td>
                        <td><span class="badge bg-info">@pm.TriggerDisplay</span></td>
                        <td>@pm.FrequencyDisplay</td>
                        <td>
                            @if (pm.NextDueDate.HasValue)
                            {
                                if (pm.IsOverdue)
                                {
                                    <span class="badge bg-danger">Overdue — @pm.NextDueDate.Value.ToString("d")</span>
                                }
                                else
                                {

                                    <small>@pm.NextDueDate.Value.ToString("d")</small>
                                }
                            }
                        </td>
                        <td>
                            <form asp-action="Toggle" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pm.Id" />
                                <button type="submit" class="btn btn-sm @(pm.IsEnabled ? "btn-success" : "btn-outline-secondary")">@(pm.IsEnabled ? "Enabled" : "Disabled")</button>
                            </form>
                        </td>
                        <td><a asp-action="Details" asp-route-id="@pm.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
