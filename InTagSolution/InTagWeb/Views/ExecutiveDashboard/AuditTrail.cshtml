@model InTagViewModelLayer.Integration.AuditTrailResultVm
@{
    var filter = ViewBag.CurrentFilter as InTagViewModelLayer.Integration.AuditTrailFilterVm;
}

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-journal-text me-2"></i>Audit Trail</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2"><input type="text" name="EntityType" value="@filter?.EntityType" class="form-control form-control-sm" placeholder="Entity Type" /></div>
            <div class="col-md-2"><input type="date" name="DateFrom" value="@filter?.DateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" /></div>
            <div class="col-md-2"><input type="date" name="DateTo" value="@filter?.DateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" /></div>
            <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-search"></i></button></div>
            <div class="col-md-1"><a asp-action="AuditTrail" class="btn btn-sm btn-outline-secondary w-100">Clear</a></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent"><span class="small text-muted">@Model.TotalCount audit entries</span></div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Date</th><th>Module</th><th>Entity</th><th>Action</th><th>User</th><th>Details</th></tr></thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No audit entries found.</td></tr>
                }
                @foreach (var entry in Model.Items)
                {
                    var aBadge = entry.Action switch { "Approved" => "bg-success", "Rejected" => "bg-danger", "Escalated" => "bg-warning text-dark", "Delegated" => "bg-info", _ => "bg-secondary" };
                    <tr>
                        <td><small>@entry.Date.ToString("g")</small></td>
                        <td><span class="badge bg-light text-dark border">@entry.Module</span></td>
                        <td>@entry.EntityType<br /><small class="text-muted">@entry.EntityReference</small></td>
                        <td><span class="badge @aBadge">@entry.Action</span></td>
                        <td>@(entry.UserName ?? "System")</td>
                        <td><small class="text-muted">@entry.Details</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-transparent d-flex justify-content-between">
            <span class="small text-muted">Page @Model.Page of @Model.TotalPages</span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (var p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")"><a class="page-link" asp-action="AuditTrail" asp-route-Page="@p" asp-route-EntityType="@filter?.EntityType" asp-route-DateFrom="@filter?.DateFrom" asp-route-DateTo="@filter?.DateTo">@p</a></li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
