@model InTagViewModelLayer.Document.ApprovalMatrixCreateVm

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-plus-circle me-2"></i>New Approval Rule</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="DocumentType" class="form-label"></label>
                            <select asp-for="DocumentType" asp-items="ViewBag.DocumentTypes" class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label">Department (optional)</label>
                            <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select">
                                <option value="">All Departments</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ApproverLevel" class="form-label"></label>
                            <input asp-for="ApproverLevel" class="form-control" type="number" min="1" max="10" />
                            <span asp-validation-for="ApproverLevel" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ApproverRole" class="form-label"></label>
                            <input asp-for="ApproverRole" class="form-control" placeholder="e.g. Quality Manager" />
                            <span asp-validation-for="ApproverRole" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EscalationHours" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="EscalationHours" class="form-control" type="number" min="1" />
                                <span class="input-group-text">hours</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Create Rule
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
