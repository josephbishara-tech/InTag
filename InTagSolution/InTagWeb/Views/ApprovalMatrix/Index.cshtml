@model IReadOnlyList<InTagViewModelLayer.Document.ApprovalMatrixVm>

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-diagram-3 me-2"></i>Approval Matrix</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>New Rule
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Document Type</th>
                    <th>Department</th>
                    <th>Level</th>
                    <th>Approver Role</th>
                    <th>Escalation</th>
                    <th>Description</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No approval rules configured.</td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge bg-info">@item.DocumentTypeDisplay</span></td>
                        <td>@(item.DepartmentName ?? "All")</td>
                        <td>
                            <span class="badge bg-primary rounded-pill">Level @item.ApproverLevel</span>
                        </td>
                        <td class="fw-bold">@item.ApproverRole</td>
                        <td>
                            @if (item.EscalationHours.HasValue)
                            {
                                <small>@item.EscalationHours h</small>
                            }
                            else
                            {
                                <small class="text-muted">—</small>
                            }
                        </td>
                        <td><small class="text-muted">@item.Description</small></td>
                        <td class="text-end">
                            <form asp-action="Delete" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this approval rule?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
