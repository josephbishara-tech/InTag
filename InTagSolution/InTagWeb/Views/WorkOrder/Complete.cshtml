@model InTagViewModelLayer.Maintenance.WorkOrderCompleteVm
@{
    var wo = ViewBag.WorkOrder as InTagViewModelLayer.Maintenance.WorkOrderDetailVm;
}

<div class="content-header"><h1><i class="bi bi-check-circle me-2"></i>Complete — @wo.WorkOrderNumber</h1></div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="alert alert-info"><i class="bi bi-info-circle me-1"></i>Completing will finalize costs, update failure records, and check SLA compliance.</div>
                <form asp-action="Complete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="WorkOrderId" />
                    <div class="mb-3"><label asp-for="Resolution" class="form-label">Resolution / Work Performed</label><textarea asp-for="Resolution" class="form-control" rows="4" placeholder="Describe how the issue was resolved..."></textarea></div>
                    <div class="mb-4"><label asp-for="ExternalCost" class="form-label">External / Contractor Cost</label><div class="input-group"><span class="input-group-text">$</span><input asp-for="ExternalCost" class="form-control" type="number" step="0.01" value="0" /></div></div>
                    <div class="d-flex gap-2"><button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Complete Work Order</button><a asp-action="Details" asp-route-id="@wo.Id" class="btn btn-outline-secondary">Cancel</a></div>
                </form>
            </div>
        </div>
    </div>
</div>
