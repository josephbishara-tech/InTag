@model InTagViewModelLayer.Maintenance.WorkOrderListResultVm
@using InTagEntitiesLayer.Enums
@{
    var filter = ViewBag.CurrentFilter as InTagViewModelLayer.Maintenance.WorkOrderFilterVm;
}

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-wrench-adjustable me-2"></i>Work Orders</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Work Order</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3"><input type="text" name="SearchTerm" value="@filter?.SearchTerm" class="form-control form-control-sm" placeholder="Search WO#, title, asset..." /></div>
            <div class="col-md-2"><select name="Status" class="form-select form-select-sm" asp-items="ViewBag.Statuses"><option value="">All Statuses</option></select></div>
            <div class="col-md-2"><select name="Type" class="form-select form-select-sm" asp-items="ViewBag.Types"><option value="">All Types</option></select></div>
            <div class="col-md-2"><select name="Priority" class="form-select form-select-sm" asp-items="ViewBag.Priorities"><option value="">All Priorities</option></select></div>
            <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-search"></i></button></div>
            <div class="col-md-1"><a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">Clear</a></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent"><span class="small text-muted">@Model.TotalCount work order(s)</span></div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>WO #</th><th>Title</th><th>Asset</th><th>Type</th><th>Priority</th><th>Status</th><th>Due</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No work orders. <a asp-action="Create">Create one</a>.</td></tr>
                }
                @foreach (var item in Model.Items)
                {
                    var sBadge = item.Status switch { WorkOrderStatus.InProgress => "bg-primary", WorkOrderStatus.Completed => "bg-success", WorkOrderStatus.Open => "bg-info", WorkOrderStatus.OnHold => "bg-warning text-dark", WorkOrderStatus.Cancelled => "bg-danger", WorkOrderStatus.Closed => "bg-dark", _ => "bg-secondary" };
                    var pBadge = item.Priority switch { WorkOrderPriority.Critical => "bg-danger", WorkOrderPriority.High => "bg-warning text-dark", _ => "bg-light text-dark border" };
                    <tr class="@(item.IsOverdue ? "table-warning" : "")">
                        <td><a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none">@item.WorkOrderNumber</a></td>
                        <td>@item.Title</td>
                        <td><small>@item.AssetCode</small><br /><small class="text-muted">@item.AssetName</small></td>
                        <td><span class="small">@item.TypeDisplay</span></td>
                        <td><span class="badge @pBadge">@item.PriorityDisplay</span></td>
                        <td><span class="badge @sBadge">@item.StatusDisplay</span></td>
                        <td>
                            @if (item.DueDate.HasValue)
                            {
                                if (item.IsOverdue)
                                {
                                    <span class="badge bg-danger">Overdue</span>
                                }
                                else
                                {

                                    <small>@item.DueDate.Value.ToString("d")</small>
                                }
                            }
                            else
                            {

                                <small class="text-muted">—</small>
                            }
                        </td>
                        <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <span class="small text-muted">Page @Model.Page of @Model.TotalPages</span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (var p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-Page="@p" asp-route-SearchTerm="@filter?.SearchTerm" asp-route-Status="@filter?.Status" asp-route-Type="@filter?.Type" asp-route-Priority="@filter?.Priority">@p</a></li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
