@model InTagViewModelLayer.Maintenance.WorkOrderCreateVm

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-plus-circle me-2"></i>New Work Order</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <h6 class="fw-bold mb-3 text-primary">Work Order Info</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-8"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /><span asp-validation-for="Title" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="AssetId" class="form-label">Asset</label><select asp-for="AssetId" asp-items="ViewBag.Assets" class="form-select"><option value="">— Select —</option></select></div>
                <div class="col-md-4"><label asp-for="Type" class="form-label"></label><select asp-for="Type" asp-items="ViewBag.Types" class="form-select"></select></div>
                <div class="col-md-4"><label asp-for="Priority" class="form-label"></label><select asp-for="Priority" asp-items="ViewBag.Priorities" class="form-select"></select></div>
                <div class="col-md-4"><label asp-for="DueDate" class="form-label"></label><input asp-for="DueDate" class="form-control" type="datetime-local" /></div>
                <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
            </div>
            <h6 class="fw-bold mb-3 text-primary">Failure Details (for Corrective/Emergency)</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-4"><label asp-for="FailureType" class="form-label"></label><select asp-for="FailureType" asp-items="ViewBag.FailureTypes" class="form-select"><option value="">— None —</option></select></div>
                <div class="col-md-4"><label asp-for="FailureCause" class="form-label"></label><input asp-for="FailureCause" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="SLATargetHours" class="form-label"></label><div class="input-group"><input asp-for="SLATargetHours" class="form-control" type="number" step="0.5" /><span class="input-group-text">hrs</span></div></div>
            </div>
            <div class="mb-4"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Create Work Order</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
