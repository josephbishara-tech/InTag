@using InTagEntitiesLayer.Interfaces
@using System.Text.Json
@inject ITenantService TenantService

@{
    var tenant = TenantService.GetCurrentTenant();
    var tenantName = tenant?.Name ?? "InTag";
    var featureFlags = new Dictionary<string, bool>();
    if (tenant != null)
    {
        featureFlags = JsonSerializer.Deserialize<Dictionary<string, bool>>(
            tenant.FeatureFlags) ?? new();
    }
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @tenantName</title>

    <link rel="stylesheet" href="~/css/bootstrap.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="d-flex" id="app-wrapper">

        <!-- ═══ SIDEBAR ═══ -->
        <nav id="sidebar" class="d-flex flex-column flex-shrink-0 bg-dark text-white collapse collapse-horizontal show">

            <!-- Brand -->
            <div class="sidebar-brand d-flex align-items-center px-3 py-3 border-bottom border-secondary">
                <i class="bi bi-tag-fill fs-4 text-success me-2"></i>
                <span class="fw-bold fs-5 sidebar-label">@tenantName</span>
            </div>

            <!-- Module Navigation -->
            <ul class="nav nav-pills flex-column mt-2 px-2 flex-grow-1">

                <!-- Dashboard (always visible) -->
                <li class="nav-item">
                    <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       href="@Url.Action("Index", "Home")">
                        <i class="bi bi-speedometer2 me-2"></i>
                        <span class="sidebar-label">Dashboard</span>
                    </a>
                </li>

                @if (featureFlags.GetValueOrDefault("Asset"))
                {
                    <li class="nav-item mt-1">
                        <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Asset" ? "active" : "")"
                           href="@Url.Action("Index", "Asset")">
                            <i class="bi bi-building-gear me-2"></i>
                            <span class="sidebar-label">Assets</span>
                        </a>
                    </li>
                }

                @if (featureFlags.GetValueOrDefault("Document"))
                {
                    <li class="nav-item mt-1">
                        <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Document" ? "active" : "")"
                           href="@Url.Action("Index", "Document")">
                            <i class="bi bi-file-earmark-text me-2"></i>
                            <span class="sidebar-label">Documents</span>
                        </a>
                    </li>
                }

                @if (featureFlags.GetValueOrDefault("Manufacturing"))
                {
                    <li class="nav-item mt-1">
                        <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Production" ? "active" : "")"
                           href="@Url.Action("Index", "Production")">
                            <i class="bi bi-gear-wide-connected me-2"></i>
                            <span class="sidebar-label">Manufacturing</span>
                        </a>
                    </li>
                }

                @if (featureFlags.GetValueOrDefault("Maintenance"))
                {
                    <li class="nav-item mt-1">
                        <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "WorkOrder" ? "active" : "")"
                           href="@Url.Action("Index", "WorkOrder")">
                            <i class="bi bi-wrench-adjustable me-2"></i>
                            <span class="sidebar-label">Maintenance</span>
                        </a>
                    </li>
                }

                @if (featureFlags.GetValueOrDefault("Inventory"))
                {
                    <li class="nav-item mt-1">
                        <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")"
                           href="@Url.Action("Index", "Inventory")">
                            <i class="bi bi-boxes me-2"></i>
                            <span class="sidebar-label">Inventory</span>
                        </a>
                    </li>
                }

                @if (featureFlags.GetValueOrDefault("Workflow"))
                {
                    <li class="nav-item mt-1">
                        <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Workflow" ? "active" : "")"
                           href="@Url.Action("Index", "Workflow")">
                            <i class="bi bi-diagram-3 me-2"></i>
                            <span class="sidebar-label">Workflows</span>
                        </a>
                    </li>
                }

                <!-- Divider -->
                <li><hr class="text-secondary my-2" /></li>

                <!-- Settings (always visible) -->
                <li class="nav-item">
                    <a class="nav-link text-white d-flex align-items-center @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")"
                       href="@Url.Action("Index", "Settings")">
                        <i class="bi bi-gear me-2"></i>
                        <span class="sidebar-label">Settings</span>
                    </a>
                </li>
            </ul>

            <!-- Sidebar footer: Collapse toggle -->
            <div class="px-3 py-2 border-top border-secondary">
                <button class="btn btn-sm btn-outline-light w-100" id="btn-collapse-sidebar"
                        title="Collapse sidebar">
                    <i class="bi bi-chevron-bar-left" id="collapse-icon"></i>
                    <span class="sidebar-label ms-1">Collapse</span>
                </button>
            </div>
        </nav>

        <!-- ═══ MAIN CONTENT AREA ═══ -->
        <div class="flex-grow-1 d-flex flex-column min-vh-100">

            <!-- Top Navbar -->
            <nav class="navbar navbar-expand-md bg-light border-bottom px-3 py-2">
                <div class="d-flex align-items-center w-100">

                    <!-- Mobile sidebar toggle -->
                    <button class="btn btn-outline-dark d-md-none me-2" type="button"
                            data-bs-toggle="collapse" data-bs-target="#sidebar">
                        <i class="bi bi-list"></i>
                    </button>

                    <!-- Page title / breadcrumb -->
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item"><a href="/">Home</a></li>
                            @if (ViewData["Module"] != null)
                            {
                                <li class="breadcrumb-item active">@ViewData["Module"]</li>
                            }
                            @if (ViewData["Title"] != null && ViewData["Title"]?.ToString() != ViewData["Module"]?.ToString())
                            {
                                <li class="breadcrumb-item active">@ViewData["Title"]</li>
                            }
                        </ol>
                    </nav>

                    <!-- Right-side items -->
                    <div class="ms-auto d-flex align-items-center gap-2">

                        <!-- Global Search -->
                        <div class="d-none d-lg-block">
                            <div class="input-group input-group-sm" style="width: 260px;">
                                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control" placeholder="Search..."
                                       id="global-search" />
                            </div>
                        </div>

                        <!-- Notifications -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary position-relative"
                                    data-bs-toggle="dropdown">
                                <i class="bi bi-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      id="notification-badge" style="display:none;">
                                    0
                                </span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" style="width: 320px;">
                                <li><h6 class="dropdown-header">Notifications</h6></li>
                                <li><p class="dropdown-item text-muted small mb-0">No new notifications</p></li>
                            </ul>
                        </div>

                        <!-- Theme Toggle -->
                        <button class="btn btn-sm btn-outline-secondary" id="btn-theme-toggle"
                                title="Toggle theme">
                            <i class="bi bi-moon-stars" id="theme-icon"></i>
                        </button>

                        <!-- User Menu -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-dark dropdown-toggle"
                                    data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>
                                <span class="d-none d-md-inline" id="user-display-name">Account</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Profile", "Account")">
                                        <i class="bi bi-person me-2"></i>Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Index", "Settings")">
                                        <i class="bi bi-gear me-2"></i>Settings
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Page Content -->
            <main class="flex-grow-1 p-4">
                <!-- Flash Messages -->
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="border-top py-2 px-4 text-muted small d-flex justify-content-between">
                <span>&copy; @DateTime.Now.Year InTag Software</span>
                <span>@tenantName &middot; @(tenant?.Tier.ToString() ?? "—") Plan</span>
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>