@{
    ViewData["Title"] = "Error";
    var traceId = Context.Request.Query["traceId"].ToString();
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
        <h2 class="mt-3">Something went wrong</h2>
        <p class="text-muted">An unexpected error occurred. Please try again or contact support.</p>
        @if (!string.IsNullOrEmpty(traceId))
        {
            <p class="small text-muted">Trace ID: <code>@traceId</code></p>
        }
        <a href="/" class="btn btn-primary mt-2">
            <i class="bi bi-house me-1"></i>Back to Dashboard
        </a>
    </div>
</div>