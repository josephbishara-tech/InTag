@model InTagViewModelLayer.Manufacturing.WorkCenterDetailVm
@using InTagEntitiesLayer.Enums

<div class="content-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-gear-wide-connected me-2"></i>@Model.Code</h1>
        <p class="text-muted mb-0">@Model.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="row g-3 mb-3">
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center"><div class="card-body py-2"><small class="text-muted">Capacity</small><h4 class="fw-bold mb-0">@Model.CapacityPerHour.ToString("N1")</h4><small>units/hr</small></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center"><div class="card-body py-2"><small class="text-muted">Labor Rate</small><h4 class="fw-bold mb-0">@Model.LaborRatePerHour.ToString("C2")</h4><small>/hr</small></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center"><div class="card-body py-2"><small class="text-muted">Overhead Rate</small><h4 class="fw-bold mb-0">@Model.OverheadRatePerHour.ToString("C2")</h4><small>/hr</small></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm text-center border-start border-primary border-4"><div class="card-body py-2"><small class="text-muted">Total Rate</small><h4 class="fw-bold text-primary mb-0">@Model.TotalRatePerHour.ToString("C2")</h4><small>/hr</small></div></div></div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Details</h6></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-4">
                        <small class="text-muted d-block">Status</small>
                        @{
                            var sBadge = Model.Status switch { WorkCenterStatus.Active => "bg-success", WorkCenterStatus.Maintenance => "bg-warning text-dark", _ => "bg-secondary" };
                        }
                        <span class="badge @sBadge fs-6">@Model.StatusDisplay</span>
                    </div>
                    <div class="col-sm-4"><small class="text-muted d-block">Available Hours/Day</small><strong>@Model.AvailableHoursPerDay.ToString("N1")</strong></div>
                    <div class="col-sm-4"><small class="text-muted d-block">Efficiency</small><strong>@Model.EfficiencyPercent%</strong></div>
                    <div class="col-sm-4"><small class="text-muted d-block">Location</small>@(Model.LocationName ?? "—")</div>
                    <div class="col-sm-4"><small class="text-muted d-block">Department</small>@(Model.DepartmentName ?? "—")</div>
                    <div class="col-sm-4"><small class="text-muted d-block">Routing Operations</small><strong>@Model.RoutingOperationCount</strong></div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <small class="text-muted d-block">Description</small>

                    <p>@Model.Description</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Cost Summary</h6></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2"><small class="text-muted">Labor</small><strong>@Model.LaborRatePerHour.ToString("C2")/hr</strong></div>
                <div class="d-flex justify-content-between mb-2"><small class="text-muted">Overhead</small><strong>@Model.OverheadRatePerHour.ToString("C2")/hr</strong></div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between"><small class="text-muted">Total</small><strong class="text-primary">@Model.TotalRatePerHour.ToString("C2")/hr</strong></div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between"><small class="text-muted">Daily Cost (est.)</small><strong>@((Model.TotalRatePerHour * Model.AvailableHoursPerDay).ToString("C2"))</strong></div>
            </div>
        </div>
    </div>
</div>
