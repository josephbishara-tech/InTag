@model IReadOnlyList<InTagViewModelLayer.Manufacturing.WorkCenterListItemVm>
@using InTagEntitiesLayer.Enums

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-gear-wide-connected me-2"></i>Work Centers</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Work Center</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Status</th><th class="text-end">Capacity/hr</th><th class="text-end">Labor $/hr</th><th class="text-end">Overhead $/hr</th><th class="text-end">Total $/hr</th><th class="text-end">Hrs/Day</th><th class="text-end">Efficiency</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="10" class="text-center text-muted py-4">No work centers. <a asp-action="Create">Create one</a>.</td></tr>
                }
                @foreach (var wc in Model)
                {
                    var sBadge = wc.Status switch { WorkCenterStatus.Active => "bg-success", WorkCenterStatus.Maintenance => "bg-warning text-dark", WorkCenterStatus.Inactive => "bg-secondary", _ => "bg-light text-dark" };
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@wc.Id" class="fw-bold text-decoration-none">@wc.Code</a></td>
                        <td>@wc.Name</td>
                        <td><span class="badge @sBadge">@wc.StatusDisplay</span></td>
                        <td class="text-end">@wc.CapacityPerHour.ToString("N1")</td>
                        <td class="text-end">@wc.LaborRatePerHour.ToString("C2")</td>
                        <td class="text-end">@wc.OverheadRatePerHour.ToString("C2")</td>
                        <td class="text-end fw-bold">@wc.TotalRatePerHour.ToString("C2")</td>
                        <td class="text-end">@wc.AvailableHoursPerDay.ToString("N1")</td>
                        <td class="text-end">@wc.EfficiencyPercent%</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@wc.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
