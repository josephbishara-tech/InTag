@model InTagViewModelLayer.Asset.AssetCreateVm

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-plus-circle me-2"></i>New Asset</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <!-- Basic Info -->
            <h6 class="fw-bold mb-3 text-primary">Basic Information</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="AssetCode" class="form-label"></label>
                    <input asp-for="AssetCode" class="form-control" />
                    <span asp-validation-for="AssetCode" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Category" class="form-label"></label>
                    <select asp-for="Category" asp-items="ViewBag.Categories" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="AssetTypeId" class="form-label"></label>
                    <select asp-for="AssetTypeId" asp-items="ViewBag.AssetTypes" class="form-select">
                        <option value="">— Select —</option>
                    </select>
                    <span asp-validation-for="AssetTypeId" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <!-- Financial -->
            <h6 class="fw-bold mb-3 text-primary">Financial</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label asp-for="PurchaseCost" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="PurchaseCost" class="form-control" type="number" step="0.01" />
                    </div>
                    <span asp-validation-for="PurchaseCost" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="SalvageValue" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="SalvageValue" class="form-control" type="number" step="0.01" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label asp-for="DepreciationMethod" class="form-label"></label>
                    <select asp-for="DepreciationMethod" asp-items="ViewBag.DepreciationMethods" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="UsefulLifeMonths" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="UsefulLifeMonths" class="form-control" type="number" />
                        <span class="input-group-text">months</span>
                    </div>
                    <span asp-validation-for="UsefulLifeMonths" class="text-danger small"></span>
                </div>
            </div>

            <!-- Location & Assignment -->
            <h6 class="fw-bold mb-3 text-primary">Location & Assignment</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="LocationId" class="form-label">Location</label>
                    <select asp-for="LocationId" asp-items="ViewBag.Locations" class="form-select">
                        <option value="">— None —</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="DepartmentId" class="form-label">Department</label>
                    <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select">
                        <option value="">— None —</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="VendorId" class="form-label">Vendor</label>
                    <select asp-for="VendorId" asp-items="ViewBag.Vendors" class="form-select">
                        <option value="">— None —</option>
                    </select>
                </div>
            </div>

            <!-- Identification -->
            <h6 class="fw-bold mb-3 text-primary">Identification</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label asp-for="SerialNumber" class="form-label"></label>
                    <input asp-for="SerialNumber" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Barcode" class="form-label"></label>
                    <input asp-for="Barcode" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Manufacturer" class="form-label"></label>
                    <input asp-for="Manufacturer" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="ModelNumber" class="form-label"></label>
                    <input asp-for="ModelNumber" class="form-control" />
                </div>
            </div>

            <!-- Dates -->
            <h6 class="fw-bold mb-3 text-primary">Dates & Warranty</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="AcquisitionDate" class="form-label"></label>
                    <input asp-for="AcquisitionDate" class="form-control" type="date" />
                </div>
                <div class="col-md-4">
                    <label asp-for="WarrantyStartDate" class="form-label"></label>
                    <input asp-for="WarrantyStartDate" class="form-control" type="date" />
                </div>
                <div class="col-md-4">
                    <label asp-for="WarrantyEndDate" class="form-label"></label>
                    <input asp-for="WarrantyEndDate" class="form-control" type="date" />
                </div>
            </div>

            <!-- Notes -->
            <div class="mb-4">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-1"></i>Create Asset
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}