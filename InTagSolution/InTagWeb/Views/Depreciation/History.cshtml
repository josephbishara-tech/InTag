@model IReadOnlyList<InTagViewModelLayer.Asset.DepreciationResultVm>
@{
    var asset = ViewBag.Asset as InTagViewModelLayer.Asset.AssetDetailVm;
}

<div class="content-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-clock-history me-2"></i>Depreciation Schedule</h1>
        <p class="text-muted mb-0">@asset.AssetCode — @asset.Name</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Forecast" asp-route-id="@asset.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-graph-up me-1"></i>Forecast
        </a>
        <a asp-controller="Asset" asp-action="Details" asp-route-id="@asset.Id" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Asset
        </a>
    </div>
</div>

<!-- Asset summary card -->
<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-2">
                <small class="text-muted">Purchase Cost</small>
                <div class="fw-bold fs-5">@asset.PurchaseCost.ToString("C2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-2">
                <small class="text-muted">Book Value</small>
                <div class="fw-bold fs-5 text-primary">@asset.CurrentBookValue.ToString("C2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-2">
                <small class="text-muted">Accumulated</small>
                <div class="fw-bold fs-5 text-danger">@asset.AccumulatedDepreciation.ToString("C2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-2">
                <small class="text-muted">Method</small>
                <div class="fw-bold fs-5">@asset.DepreciationMethod</div>
            </div>
        </div>
    </div>
</div>

<!-- History table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent">
        <h6 class="mb-0 fw-bold">@Model.Count period(s) recorded</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Period</th>
                    <th class="text-end">Opening Value</th>
                    <th class="text-end">Depreciation</th>
                    <th class="text-end">Accumulated</th>
                    <th class="text-end">Closing Value</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No depreciation records yet.</td></tr>
                }
                @foreach (var record in Model)
                {
                    <tr>
                        <td class="fw-bold">@record.Period</td>
                        <td class="text-end">@record.OpeningBookValue.ToString("N2")</td>
                        <td class="text-end text-danger">-@record.DepreciationAmount.ToString("N2")</td>
                        <td class="text-end">@record.AccumulatedDepreciation.ToString("N2")</td>
                        <td class="text-end fw-bold">@record.ClosingBookValue.ToString("N2")</td>
                        <td>
                            @if (record.IsFullyDepreciated)
                            {
                                <span class="badge bg-warning text-dark">Fully Depreciated</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
