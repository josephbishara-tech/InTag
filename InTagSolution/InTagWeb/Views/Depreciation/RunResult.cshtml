@model InTagViewModelLayer.Asset.BulkDepreciationResultVm

<div class="content-header">
    <h1><i class="bi bi-check-circle me-2"></i>Depreciation Run Complete</h1>
</div>

<!-- Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-2">
                <small class="text-muted">Period</small>
                <div class="fw-bold fs-5">@Model.Period</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center border-start border-success border-4">
            <div class="card-body py-2">
                <small class="text-muted">Processed</small>
                <div class="fw-bold fs-5 text-success">@Model.AssetsProcessed</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center border-start border-warning border-4">
            <div class="card-body py-2">
                <small class="text-muted">Skipped</small>
                <div class="fw-bold fs-5 text-warning">@Model.AssetsSkipped</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center border-start border-primary border-4">
            <div class="card-body py-2">
                <small class="text-muted">Total Depreciation</small>
                <div class="fw-bold fs-5 text-primary">@Model.TotalDepreciation.ToString("C2")</div>
            </div>
        </div>
    </div>
</div>

<!-- Details table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent d-flex justify-content-between">
        <h6 class="mb-0 fw-bold">Details</h6>
        <a asp-action="Index" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-bar-chart me-1"></i>View Summary
        </a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Asset Code</th>
                    <th>Name</th>
                    <th>Status</th>
                    <th class="text-end">Depreciation</th>
                    <th class="text-end">Closing Value</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Details.OrderBy(d => d.Status))
                {
                    var rowClass = item.Status switch
                    {
                                "Processed" => "",
                                "Skipped" => "table-light text-muted",
                                "Failed" => "table-danger",
                        _ => ""
                    };
                    var badgeClass = item.Status switch
                    {
                                "Processed" => "bg-success",
                                "Skipped" => "bg-secondary",
                                "Failed" => "bg-danger",
                        _ => "bg-secondary"
                    };
                    <tr class="@rowClass">
                        <td class="fw-bold">@item.AssetCode</td>
                        <td>@item.AssetName</td>
                        <td><span class="badge @badgeClass">@item.Status</span></td>
                        <td class="text-end">
                            @if (item.DepreciationAmount > 0)
                            {
                                <span class="text-danger">-@item.DepreciationAmount.ToString("N2")</span>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td class="text-end">@item.ClosingBookValue.ToString("N2")</td>
                        <td><small class="text-muted">@item.ErrorMessage</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
