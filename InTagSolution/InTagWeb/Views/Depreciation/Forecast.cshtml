@model IReadOnlyList<InTagViewModelLayer.Asset.DepreciationForecastVm>
@{
    var asset = ViewBag.Asset as InTagViewModelLayer.Asset.AssetDetailVm;
    var history = ViewBag.History as IReadOnlyList<InTagViewModelLayer.Asset.DepreciationResultVm>;
}

<div class="content-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-graph-up me-2"></i>Depreciation Forecast</h1>
        <p class="text-muted mb-0">@asset.AssetCode — @asset.Name (@asset.DepreciationMethod)</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="History" asp-route-id="@asset.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-clock-history me-1"></i>History
        </a>
        <a asp-controller="Asset" asp-action="Details" asp-route-id="@asset.Id" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<!-- Visual chart: Book value over time -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Projected Book Value Decline</h6></div>
    <div class="card-body">
        @{
            var allPeriods = new List<(string Period, decimal Value, bool IsHistory)>();
            if (history != null)
            {
                foreach (var h in history)
                    allPeriods.Add((h.Period, h.ClosingBookValue, true));
            }
            foreach (var f in Model)
                allPeriods.Add((f.Period, f.ClosingBookValue, false));

            var maxVal = asset.PurchaseCost;
        }
        <div class="d-flex align-items-end gap-1" style="height: 200px; overflow-x: auto;">
            @foreach (var p in allPeriods)
            {
                var height = maxVal > 0 ? (double)(p.Value / maxVal * 100) : 0;
                var bgColor = p.IsHistory ? "bg-primary" : "bg-info bg-opacity-50";
                <div class="d-flex flex-column align-items-center" style="min-width: 32px;">
                    <small class="text-muted" style="font-size: 0.6rem;">@p.Value.ToString("C0")</small>
                    <div class="@bgColor rounded-top" style="width: 24px; height: @height%;"></div>
                    <small class="text-muted" style="font-size: 0.55rem; writing-mode: vertical-rl;">@p.Period</small>
                </div>
            }
        </div>
        <div class="mt-2 d-flex gap-3 small">
            <span><span class="badge bg-primary">&nbsp;</span> Actual</span>
            <span><span class="badge bg-info bg-opacity-50">&nbsp;</span> Projected</span>
        </div>
    </div>
</div>

<!-- Forecast table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent">
        <h6 class="mb-0 fw-bold">Projected Schedule — @Model.Count months</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Period</th>
                    <th class="text-end">Opening</th>
                    <th class="text-end">Depreciation</th>
                    <th class="text-end">Accumulated</th>
                    <th class="text-end">Closing</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model)
                {
                    <tr class="@(row.ClosingBookValue <= (asset.SalvageValue ?? 0) ? "table-warning" : "")">
                        <td>@row.Period</td>
                        <td class="text-end">@row.OpeningBookValue.ToString("N2")</td>
                        <td class="text-end text-danger">-@row.DepreciationAmount.ToString("N2")</td>
                        <td class="text-end">@row.AccumulatedDepreciation.ToString("N2")</td>
                        <td class="text-end fw-bold">@row.ClosingBookValue.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
