@model InTagViewModelLayer.Inventory.ReorderReportVm
@using InTagEntitiesLayer.Enums

<div class="content-header"><h1><i class="bi bi-exclamation-diamond me-2"></i>Reorder Report</h1></div>

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card border-0 shadow-sm text-center border-start border-danger border-4"><div class="card-body py-2"><small class="text-muted">Out of Stock</small><h3 class="fw-bold text-danger mb-0">@Model.OutOfStockCount</h3></div></div></div>
    <div class="col-md-4"><div class="card border-0 shadow-sm text-center border-start border-danger border-4"><div class="card-body py-2"><small class="text-muted">Below Minimum</small><h3 class="fw-bold text-danger mb-0">@Model.BelowMinimumCount</h3></div></div></div>
    <div class="col-md-4"><div class="card border-0 shadow-sm text-center border-start border-warning border-4"><div class="card-body py-2"><small class="text-muted">Below Reorder Point</small><h3 class="fw-bold text-warning mb-0">@Model.BelowReorderCount</h3></div></div></div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Product</th><th>Warehouse</th><th class="text-end">On Hand</th><th class="text-end">Reorder Pt</th><th class="text-end">Min</th><th class="text-end">Suggested Qty</th><th>Status</th></tr></thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">All stock levels are healthy.</td></tr>
                }
                @foreach (var item in Model.Items)
                {
                    var sBadge = item.Status switch { ReorderStatus.OutOfStock => "bg-danger", ReorderStatus.BelowMinimum => "bg-danger", ReorderStatus.BelowReorderPoint => "bg-warning text-dark", ReorderStatus.Overstock => "bg-info", _ => "bg-secondary" };
                    <tr class="@(item.Status == ReorderStatus.OutOfStock ? "table-danger" : item.Status == ReorderStatus.BelowMinimum ? "table-warning" : "")">
                        <td><strong>@item.ProductCode</strong><br /><small class="text-muted">@item.ProductName</small></td>
                        <td>@item.WarehouseCode</td>
                        <td class="text-end fw-bold">@item.QuantityOnHand.ToString("N2")</td>
                        <td class="text-end">@item.ReorderPoint.ToString("N2")</td>
                        <td class="text-end">@item.MinimumLevel.ToString("N2")</td>
                        <td class="text-end fw-bold text-primary">@item.SuggestedOrderQty.ToString("N2")</td>
                        <td><span class="badge @sBadge">@item.StatusDisplay</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
