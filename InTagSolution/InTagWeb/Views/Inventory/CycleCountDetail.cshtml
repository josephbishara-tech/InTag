@model InTagViewModelLayer.Inventory.CycleCountDetailVm

<div class="content-header d-flex justify-content-between align-items-center">
    <div><h1><i class="bi bi-clipboard-data me-2"></i>@Model.CountNumber</h1><p class="text-muted mb-0">@Model.WarehouseName — @Model.CountDate.ToString("g")</p></div>
    <div class="d-flex gap-2">
        @if (!Model.IsCompleted)
        {
            <form asp-action="CompleteCycleCount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Complete cycle count and apply adjustments?')"><i class="bi bi-check-circle me-1"></i>Complete & Adjust</button>
            </form>
        }
        <a asp-action="CycleCounts" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="card border-0 shadow-sm text-center"><div class="card-body py-2"><small class="text-muted">Total Lines</small><h4 class="fw-bold mb-0">@Model.TotalLines</h4></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm text-center"><div class="card-body py-2"><small class="text-muted">Variances</small><h4 class="fw-bold text-warning mb-0">@Model.VarianceCount</h4></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm text-center"><div class="card-body py-2"><small class="text-muted">Status</small><h4 class="fw-bold mb-0"><span class="badge @(Model.IsCompleted ? "bg-success" : "bg-warning text-dark") fs-6">@(Model.IsCompleted ? "Completed" : "In Progress")</span></h4></div></div></div>
    <div class="col-md-3"><div class="card border-0 shadow-sm text-center"><div class="card-body py-2"><small class="text-muted">Total Variance</small><h4 class="fw-bold text-danger mb-0">@Model.TotalVarianceValue.ToString("N2") units</h4></div></div></div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Product</th><th>Bin</th><th class="text-end">System Qty</th><th class="text-end">Counted</th><th class="text-end">Variance</th><th class="text-end">Var %</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    var varClass = line.Variance > 0 ? "text-success" : line.Variance < 0 ? "text-danger" : "";
                    <tr class="@(line.Variance != 0 && !line.IsAdjusted ? "table-warning" : "")">
                        <td><strong>@line.ProductCode</strong><br /><small class="text-muted">@line.ProductName</small></td>
                        <td><small>@(line.BinCode ?? "—")</small></td>
                        <td class="text-end">@line.SystemQuantity.ToString("N2")</td>
                        <td class="text-end">
                            @if (!Model.IsCompleted)
                            {
                                <form asp-action="UpdateCountLine" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="CycleCountLineId" value="@line.Id" />
                                    <input type="hidden" name="cycleCountId" value="@Model.Id" />
                                    <input type="number" name="CountedQuantity" value="@line.CountedQuantity" class="form-control form-control-sm d-inline" style="width:100px;" step="0.01" onchange="this.form.submit()" />
                                </form>
                            }
                            else
                            {

                                @line.CountedQuantity.ToString("N2")
                            }
                        </td>
                        <td class="text-end fw-bold @varClass">@(line.Variance > 0 ? "+" : "")@line.Variance.ToString("N2")</td>
                        <td class="text-end @varClass">@(line.Variance != 0 ? $"{line.VariancePercent:N1}%" : "—")</td>
                        <td>@if (line.IsAdjusted) {
                        <span class="badge bg-success">Adjusted</span>
                    } else if (line.Variance != 0)
                    {

                        <span class="badge bg-warning text-dark">Pending</span>
                    }
</td>
                    <td></td>
                </tr>
                                }
            </tbody>
        </table>
    </div>
</div>
