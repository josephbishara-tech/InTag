@model InTagViewModelLayer.Inventory.StockListResultVm
@using InTagEntitiesLayer.Enums
@{
    var filter = ViewBag.CurrentFilter as InTagViewModelLayer.Inventory.StockFilterVm;
}

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-boxes me-2"></i>Inventory</h1>
    <a asp-action="RecordTransaction" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Record Transaction</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3"><input type="text" name="SearchTerm" value="@filter?.SearchTerm" class="form-control form-control-sm" placeholder="Search product, lot..." /></div>
            <div class="col-md-2"><select name="WarehouseId" class="form-select form-select-sm" asp-items="ViewBag.Warehouses"><option value="">All Warehouses</option></select></div>
            <div class="col-md-2">
                <select name="SortBy" class="form-select form-select-sm">
                    <option value="ProductCode" selected="@(filter?.SortBy == "ProductCode")">Product Code</option>
                    <option value="quantity" selected="@(filter?.SortBy == "quantity")">Quantity</option>
                    <option value="value" selected="@(filter?.SortBy == "value")">Value</option>
                </select>
            </div>
            <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-search"></i></button></div>
            <div class="col-md-1"><a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">Clear</a></div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent"><span class="small text-muted">@Model.TotalCount stock item(s)</span></div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Product</th><th>Warehouse</th><th>Bin</th><th class="text-end">On Hand</th><th class="text-end">Available</th><th class="text-end">Unit Cost</th><th class="text-end">Value</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>No stock items. <a asp-action="RecordTransaction">Record a receipt</a>.</td></tr>
                }
                @foreach (var item in Model.Items)
                {
                    var rBadge = item.ReorderStatus switch
                    {
                        ReorderStatus.OutOfStock => "bg-danger",
                        ReorderStatus.BelowMinimum => "bg-danger",
                        ReorderStatus.BelowReorderPoint => "bg-warning text-dark",
                        ReorderStatus.Overstock => "bg-info",
                        _ => ""
                    };
                    <tr class="@(item.ReorderStatus == ReorderStatus.OutOfStock ? "table-danger" : item.ReorderStatus == ReorderStatus.BelowMinimum ? "table-warning" : "")">
                        <td>
                            <a asp-action="StockDetail" asp-route-id="@item.Id" class="fw-bold text-decoration-none">@item.ProductCode</a>
                            <br /><small class="text-muted">@item.ProductName</small>
                            @if (!string.IsNullOrEmpty(item.LotNumber))
                            {
                                <br />
                                <small class="badge bg-light text-dark border">Lot: @item.LotNumber</small>
     }
                        </td>
                        <td>@item.WarehouseCode</td>
                        <td><small>@(item.BinCode ?? "—")</small></td>
                        <td class="text-end fw-bold">@item.QuantityOnHand.ToString("N2")</td>
                        <td class="text-end">@item.QuantityAvailable.ToString("N2")</td>
                        <td class="text-end">@item.UnitCost.ToString("C4")</td>
                        <td class="text-end">@item.TotalValue.ToString("C2")</td>
                        <td>
                            @if (item.ReorderStatus != ReorderStatus.Normal)
                            {
                                <span class="badge @rBadge">@item.ReorderStatus</span>
                            }
                        </td>
                        <td><a asp-action="StockDetail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <span class="small text-muted">Page @Model.Page of @Model.TotalPages</span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (var p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-Page="@p" asp-route-SearchTerm="@filter?.SearchTerm" asp-route-WarehouseId="@filter?.WarehouseId">@p</a></li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
