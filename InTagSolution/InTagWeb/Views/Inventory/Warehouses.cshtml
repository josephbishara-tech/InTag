@model IReadOnlyList<InTagViewModelLayer.Inventory.WarehouseListVm>

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-building me-2"></i>Warehouses</h1>
    <a asp-action="CreateWarehouse" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Warehouse</a>
</div>

<div class="row g-3">
    @foreach (var wh in Model)
    {
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-bold">@wh.Code <small class="text-muted fw-normal">— @wh.Name</small></h5>
                    @if (!string.IsNullOrEmpty(wh.Address))
                    {
                        <p class="small text-muted mb-2">@wh.Address</p>
                    }
                    <div class="d-flex gap-3">
                        <span><i class="bi bi-grid-3x3 me-1"></i>@wh.BinCount bins</span>
                        <span><i class="bi bi-box me-1"></i>@wh.StockItemCount items</span>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-top">
                    <form asp-action="CreateBin" method="post" class="row g-1 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="WarehouseId" value="@wh.Id" />
                        <div class="col-4"><input type="text" name="BinCode" class="form-control form-control-sm" placeholder="Bin code" required /></div>
                        <div class="col-3"><input type="text" name="Aisle" class="form-control form-control-sm" placeholder="Aisle" /></div>
                        <div class="col-3"><input type="text" name="Shelf" class="form-control form-control-sm" placeholder="Shelf" /></div>
                        <div class="col-2"><button type="submit" class="btn btn-sm btn-outline-primary w-100"><i class="bi bi-plus"></i></button></div>
                    </form>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12"><p class="text-center text-muted py-4">No warehouses. <a asp-action="CreateWarehouse">Create one</a>.</p></div>
    }
</div>
