@model IReadOnlyList<InTagViewModelLayer.Inventory.CycleCountListItemVm>

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-clipboard-data me-2"></i>Cycle Counts</h1>
    <form asp-action="CreateCycleCount" method="post" class="d-flex gap-2">
        @Html.AntiForgeryToken()
        <select name="WarehouseId" class="form-select form-select-sm" asp-items="ViewBag.Warehouses" style="width:180px;" required><option value="">— Warehouse —</option></select>
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>New Count</button>
    </form>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Count #</th><th>Warehouse</th><th>Date</th><th class="text-end">Lines</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No cycle counts.</td></tr>
                }
                @foreach (var cc in Model)
                {
                    <tr>
                        <td><a asp-action="CycleCountDetail" asp-route-id="@cc.Id" class="fw-bold text-decoration-none">@cc.CountNumber</a></td>
                        <td>@cc.WarehouseName</td>
                        <td><small>@cc.CountDate.ToString("g")</small></td>
                        <td class="text-end">@cc.LineCount</td>
                        <td><span class="badge @(cc.IsCompleted ? "bg-success" : "bg-warning text-dark")">@(cc.IsCompleted ? "Completed" : "In Progress")</span></td>
                        <td><a asp-action="CycleCountDetail" asp-route-id="@cc.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
