@model InTagViewModelLayer.Inventory.TransactionCreateVm

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-plus-circle me-2"></i>Record Transaction</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="RecordTransaction" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <h6 class="fw-bold mb-3 text-primary">Transaction</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-3"><label asp-for="Type" class="form-label"></label><select asp-for="Type" asp-items="ViewBag.TransactionTypes" class="form-select"></select></div>
                <div class="col-md-3"><label asp-for="ProductId" class="form-label">Product</label><select asp-for="ProductId" asp-items="ViewBag.Products" class="form-select"><option value="">— Select —</option></select></div>
                <div class="col-md-3"><label asp-for="Quantity" class="form-label"></label><input asp-for="Quantity" class="form-control" type="number" step="0.01" /><span asp-validation-for="Quantity" class="text-danger small"></span></div>
                <div class="col-md-3"><label asp-for="UnitCost" class="form-label"></label><div class="input-group"><span class="input-group-text">$</span><input asp-for="UnitCost" class="form-control" type="number" step="0.0001" /></div></div>
            </div>

            <h6 class="fw-bold mb-3 text-primary">Location</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-3"><label asp-for="WarehouseId" class="form-label">From Warehouse</label><select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" class="form-select"><option value="">— Select —</option></select></div>
                <div class="col-md-3"><label asp-for="ToWarehouseId" class="form-label">To Warehouse (Transfer)</label><select asp-for="ToWarehouseId" asp-items="ViewBag.Warehouses" class="form-select"><option value="">— N/A —</option></select></div>
            </div>

            <h6 class="fw-bold mb-3 text-primary">Traceability</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-3"><label asp-for="LotNumber" class="form-label"></label><input asp-for="LotNumber" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="SerialNumber" class="form-label"></label><input asp-for="SerialNumber" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="ReferenceNumber" class="form-label"></label><input asp-for="ReferenceNumber" class="form-control" placeholder="PO#, WO#, etc." /></div>
                <div class="col-md-3"><label asp-for="Reason" class="form-label"></label><input asp-for="Reason" class="form-control" /></div>
            </div>

            <div class="mb-4"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>

            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Record Transaction</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
