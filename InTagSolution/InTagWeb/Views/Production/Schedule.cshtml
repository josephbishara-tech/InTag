@{
    var order = ViewBag.Order as InTagViewModelLayer.Manufacturing.ProductionOrderDetailVm;
}

<div class="content-header"><h1><i class="bi bi-calendar-week me-2"></i>Schedule Order @order.OrderNumber</h1></div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="alert alert-info"><i class="bi bi-info-circle me-1"></i>Forward scheduling will calculate dates for each routing operation based on work center capacity.</div>
                <form asp-action="Schedule" asp-route-id="@order.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3"><label class="form-label">Start Date</label><input type="datetime-local" name="startDate" class="form-control" value="@DateTimeOffset.UtcNow.ToString("yyyy-MM-ddTHH:mm")" required /></div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-calendar-week me-1"></i>Schedule</button>
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
