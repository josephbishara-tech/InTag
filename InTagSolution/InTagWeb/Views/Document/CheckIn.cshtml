@model InTagViewModelLayer.Document.RevisionCreateVm
@{
    var doc = ViewBag.Document as InTagViewModelLayer.Document.DocumentDetailVm;
}

<div class="content-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-box-arrow-in-down me-2"></i>Check In</h1>
        <p class="text-muted mb-0">@doc.DocNumber — @doc.Title (current: v @doc.CurrentVersion)</p>
    </div>
    <a asp-action="Details" asp-route-id="@doc.Id" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-1"></i>
                    Checking in will create a <strong>new revision</strong> and release the editing lock.
                </div>

                <form asp-action="CheckIn" asp-route-id="@doc.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="DocumentId" value="@doc.Id" />

                    <div class="mb-4">
                        <label asp-for="ChangeDescription" class="form-label"></label>
                        <textarea asp-for="ChangeDescription" class="form-control" rows="4"
                                  placeholder="Describe what was changed in this revision..."></textarea>
                        <span asp-validation-for="ChangeDescription" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-box-arrow-in-down me-1"></i>Check In
                        </button>
                        <a asp-action="Details" asp-route-id="@doc.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
