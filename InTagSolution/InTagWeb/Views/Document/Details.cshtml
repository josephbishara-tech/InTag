@model InTagViewModelLayer.Document.DocumentDetailVm
@using InTagEntitiesLayer.Enums

<div class="content-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-file-earmark-text me-2"></i>@Model.DocNumber</h1>
        <p class="text-muted mb-0">@Model.Title</p>
    </div>
    <div class="d-flex gap-2">
        @if (Model.Status != DocumentStatus.Obsolete && Model.Status != DocumentStatus.Archived)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- ═══ Left Column ═══ -->
    <div class="col-lg-8">

        <!-- General Info -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">General Information</h6></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-4">
                        <small class="text-muted d-block">Document Number</small>
                        <strong>@Model.DocNumber</strong>
                    </div>
                    <div class="col-sm-4">
                        <small class="text-muted d-block">Version</small>
                        <span class="badge bg-light text-dark fs-6">v @Model.CurrentVersion</span>
                    </div>
                    <div class="col-sm-4">
                        <small class="text-muted d-block">Status</small>
                        @{
                            var detailBadge = Model.Status switch
                            {
                                DocumentStatus.Published => "bg-success",
                                DocumentStatus.Draft => "bg-secondary",
                                DocumentStatus.InReview => "bg-info",
                                DocumentStatus.Approved => "bg-primary",
                                DocumentStatus.Obsolete => "bg-danger",
                                DocumentStatus.Archived => "bg-dark",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @detailBadge">@Model.StatusDisplay</span>
                        @if (Model.IsCheckedOut)
                        {
                            <span class="badge bg-warning text-dark ms-1"><i class="bi bi-lock-fill"></i> Checked Out</span>
                        }
                    </div>
                    <div class="col-sm-4"><small class="text-muted d-block">Type</small>@Model.TypeDisplay</div>
                    <div class="col-sm-4"><small class="text-muted d-block">Category</small>@Model.CategoryDisplay</div>
                    <div class="col-sm-4"><small class="text-muted d-block">Department</small>@(Model.DepartmentName ?? "—")</div>
                    @if (!string.IsNullOrEmpty(Model.IsoReference))
                    {
                        <div class="col-sm-4"><small class="text-muted d-block">ISO Reference</small>@Model.IsoReference</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ConfidentialityLevel))
                    {
                        <div class="col-sm-4"><small class="text-muted d-block">Confidentiality</small>@Model.ConfidentialityLevel</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Tags))
                    {
                        <div class="col-12">
                            <small class="text-muted d-block">Tags</small>
                            @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="badge bg-light text-dark border me-1">@tag.Trim()</span>
                            }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="col-12"><small class="text-muted d-block">Description</small>@Model.Description</div>
                    }
                </div>
            </div>
        </div>

        <!-- ═══ Revision History with Files ═══ -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent">
                <h6 class="mb-0 fw-bold">Revision History & Files (@Model.RevisionCount)</h6>
            </div>
            <div class="card-body p-0">
                @foreach (var rev in Model.Revisions)
                {
                    var appBadge = rev.ApprovalStatus switch
                    {
                        ApprovalAction.Approved => "bg-success",
                        ApprovalAction.Rejected => "bg-danger",
                        ApprovalAction.ReturnedForRevision => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                    <div class="border-bottom p-3">
                        <!-- Revision Header -->
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge bg-primary rounded-pill me-1">v @rev.RevisionNumber</span>
                                <strong>@rev.ChangeDescription</strong>
                                <br /><small class="text-muted">@rev.CreatedDate.ToString("g")</small>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @appBadge">@rev.ApprovalStatusDisplay</span>
                                @if (rev.ApprovalStatus == ApprovalAction.Pending)
                                {
                                    <form asp-action="ApproveRevision" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="RevisionId" value="@rev.Id" />
                                        <input type="hidden" name="IsApproved" value="true" />
                                        <input type="hidden" name="documentId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Approve"
                                                onclick="return confirm('Approve this revision?')">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form asp-action="ApproveRevision" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="RevisionId" value="@rev.Id" />
                                        <input type="hidden" name="IsApproved" value="false" />
                                        <input type="hidden" name="documentId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Reject"
                                                onclick="return confirm('Reject this revision?')">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(rev.ApprovalComments))
                        {
                            <div class="mt-1"><small class="text-muted"><i class="bi bi-chat-left-text me-1"></i>@rev.ApprovalComments</small></div>
                        }

                        <!-- Files for this revision -->
                        @if (rev.Files.Any())
                        {
                            <div class="mt-2">
                                @foreach (var file in rev.Files)
                                {
                                    <div class="d-inline-flex align-items-center me-3 mb-1">
                                        <i class="bi @file.FileIcon me-1 text-primary"></i>
                                        <a asp-action="DownloadFile" asp-route-fileId="@file.Id"
                                               class="text-decoration-none small fw-bold">
                                            @file.FileName
                                        </a>
                                        <small class="text-muted ms-1">(@file.FileSizeDisplay)</small>
                                        @if (rev.ApprovalStatus == ApprovalAction.Pending)
                                        {
                                            <form asp-action="DeleteFile" method="post" class="d-inline ms-1">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="fileId" value="@file.Id" />
                                                <input type="hidden" name="documentId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-link btn-sm text-danger p-0"
                                                        onclick="return confirm('Delete this file?')">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                @if (rev.Files.Count > 1)
                                {
                                    <div class="mt-1">
                                        <a asp-action="DownloadRevisionFiles" asp-route-revisionId="@rev.Id"
                                               class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-file-zip me-1"></i>Download All as ZIP
                                        </a>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <small class="text-muted mt-1 d-block"><i class="bi bi-folder2-open me-1"></i>No files attached</small>
                        }
                    </div>
                }

                @if (!Model.Revisions.Any())
                {
                    <p class="text-muted text-center py-3 mb-0">No revisions yet.</p>
                }
            </div>

            <!-- Upload to latest pending revision -->
            @{
                var latestRevision = Model.Revisions.FirstOrDefault();
            }
            @if (latestRevision != null && latestRevision.ApprovalStatus == ApprovalAction.Pending)
            {
                <div class="card-footer bg-transparent">
                    <form asp-action="UploadFile" method="post" enctype="multipart/form-data"
                          class="d-flex gap-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="revisionId" value="@latestRevision.Id" />
                        <input type="hidden" name="documentId" value="@Model.Id" />
                        <div class="flex-grow-1">
                            <label class="form-label small mb-1">Attach file to v @latestRevision.RevisionNumber</label>
                            <input type="file" name="file" class="form-control form-control-sm" required />
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary">
                            <i class="bi bi-upload me-1"></i>Upload
                        </button>
                    </form>
                    <small class="text-muted">Max 50MB. Supported: PDF, DOCX, XLSX, PNG, JPG, DWG, ZIP</small>
                </div>
            }
        </div>

        <!-- Distribution Records -->
        @if (Model.Distributions.Any())
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Distribution</h6></div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-light"><tr><th>Recipient</th><th>Method</th><th>Sent</th><th>Acknowledged</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var d in Model.Distributions)
                            {
                                <tr>
                                    <td>@d.RecipientName</td>
                                    <td><small>@d.Method</small></td>
                                    <td><small>@d.SentDate.ToString("g")</small></td>
                                    <td>
                                        @if (d.IsAcknowledged)
                                        {
                                            <span class="badge bg-success">@d.AcknowledgedDate?.ToString("g")</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!d.IsAcknowledged)
                                        {
                                            <form asp-action="Acknowledge" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="distributionId" value="@d.Id" />
                                                <input type="hidden" name="documentId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">Ack</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- ═══ Right Column ═══ -->
    <div class="col-lg-4">

        <!-- Current Files — Quick Download -->
        @if (Model.LatestFiles.Any())
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Current Files (v @Model.CurrentVersion)</h6></div>
                <div class="card-body d-grid gap-1">
                    @foreach (var file in Model.LatestFiles)
                    {
                        <a asp-action="DownloadFile" asp-route-fileId="@file.Id"
                               class="btn btn-outline-info btn-sm text-start">
                            <i class="bi @file.FileIcon me-1"></i>@file.FileName
                            <small class="text-muted float-end">@file.FileSizeDisplay</small>
                        </a>
                    }
                    @if (Model.LatestFiles.Count > 1)
                    {
                        var firstRevision = Model.Revisions.FirstOrDefault();
                        if (firstRevision != null)
                        {
                            <a asp-action="DownloadRevisionFiles" asp-route-revisionId="@firstRevision.Id"
                                   class="btn btn-info btn-sm mt-1">
                                <i class="bi bi-file-zip me-1"></i>Download All as ZIP
                            </a>
                        }
                    }
                </div>
            </div>
        }

        <!-- Actions -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Actions</h6></div>
            <div class="card-body d-grid gap-2">

                @* Check-in / Check-out *@
                @if (!Model.IsCheckedOut && Model.Status != DocumentStatus.Obsolete && Model.Status != DocumentStatus.Archived)
                {
                    <form asp-action="CheckOut" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-box-arrow-up me-1"></i>Check Out
                        </button>
                    </form>
                }
                @if (Model.IsCheckedOut)
                {
                    <div class="alert alert-warning py-2 small mb-2">
                        <i class="bi bi-lock-fill me-1"></i>Checked out
                        @if (Model.CheckedOutByName != null)
                        {
                            <span>by @Model.CheckedOutByName</span>
                        }
                        @if (Model.CheckedOutDate.HasValue)
                        {
                            <span>on @Model.CheckedOutDate.Value.ToString("g")</span>
                        }
                    </div>
                    <a asp-action="CheckIn" asp-route-id="@Model.Id" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-box-arrow-in-down me-1"></i>Check In (New Revision)
                    </a>
                    <form asp-action="CancelCheckOut" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-secondary btn-sm w-100"
                                onclick="return confirm('Cancel check-out?')">
                            <i class="bi bi-x-circle me-1"></i>Cancel Check-Out
                        </button>
                    </form>
                }

                @* Lifecycle *@
                @if (Model.Status == DocumentStatus.Approved || Model.Status == DocumentStatus.Draft)
                {
                    <form asp-action="Publish" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success btn-sm w-100"
                                onclick="return confirm('Publish this document?')">
                            <i class="bi bi-globe me-1"></i>Publish
                        </button>
                    </form>
                }
                @if (Model.Status == DocumentStatus.Published)
                {
                    <form asp-action="Obsolete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm w-100"
                                onclick="return confirm('Mark as obsolete?')">
                            <i class="bi bi-exclamation-triangle me-1"></i>Obsolete
                        </button>
                    </form>
                }
                @if (Model.Status != DocumentStatus.Archived && Model.Status != DocumentStatus.Draft)
                {
                    <form asp-action="Archive" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-dark btn-sm w-100"
                                onclick="return confirm('Archive this document?')">
                            <i class="bi bi-archive me-1"></i>Archive
                        </button>
                    </form>
                }

                @if (Model.Status == DocumentStatus.Draft)
                {
                    <hr class="my-1" />
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                onclick="return confirm('Delete this document?')">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- Review Schedule -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Review Schedule</h6></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2"><small class="text-muted">Review Cycle</small><span>@Model.ReviewCycle</span></div>
                <div class="d-flex justify-content-between mb-2"><small class="text-muted">Effective Date</small><span>@(Model.EffectiveDate?.ToString("d") ?? "—")</span></div>
                <div class="d-flex justify-content-between mb-2">
                    <small class="text-muted">Next Review</small>
                    @if (Model.IsOverdueForReview)
                    {
                        <span class="badge bg-danger">Overdue — @Model.NextReviewDate!.Value.ToString("d")</span>
                    }
                    else if (Model.NextReviewDate.HasValue)
                    {

                        <span>@Model.NextReviewDate.Value.ToString("d")</span>
                    }
                    else
                    {

                        <span>—</span>
                    }
                </div>
                <div class="d-flex justify-content-between"><small class="text-muted">Expiry</small><span>@(Model.ExpiryDate?.ToString("d") ?? "—")</span></div>
            </div>
        </div>

        <!-- Audit -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent"><h6 class="mb-0 fw-bold">Audit</h6></div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-1"><small class="text-muted">Created</small><span>@Model.CreatedDate.ToString("g")</span></div>
                @if (Model.ModifiedDate.HasValue)
                {
                    <div class="d-flex justify-content-between"><small class="text-muted">Modified</small><span>@Model.ModifiedDate.Value.ToString("g")</span></div>
                }
            </div>
        </div>
    </div>
</div>
