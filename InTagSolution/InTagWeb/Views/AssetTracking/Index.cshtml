@model IReadOnlyList<InTagViewModelLayer.Asset.TrackingRequestListVm>
@using InTagEntitiesLayer.Enums

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-qr-code-scan me-2"></i>Asset Tracking</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Tracking Request</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Request #</th><th>Title</th><th>Location</th><th>Assets</th><th>Progress</th><th>Status</th><th>Created</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-qr-code fs-3 d-block mb-2"></i>No tracking requests. <a asp-action="Create">Create one</a>.</td></tr>
                }
                @foreach (var r in Model)
                {
                    var sBadge = r.Status switch { TrackingRequestStatus.Open => "bg-info", TrackingRequestStatus.InProgress => "bg-primary", TrackingRequestStatus.Completed => "bg-success", TrackingRequestStatus.Cancelled => "bg-secondary", _ => "bg-warning text-dark" };
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@r.Id" class="fw-bold text-decoration-none">@r.RequestNumber</a></td>
                        <td>@r.Title</td>
                        <td>@r.LocationName</td>
                        <td class="text-center">@r.ScannedCount / @r.TotalAssets</td>
                        <td style="width:120px;">
                            <div class="d-flex align-items-center gap-1">
                                <div class="progress flex-grow-1" style="height:6px;"><div class="progress-bar @(r.ProgressPercent >= 100 ? "bg-success" : "bg-primary")" style="width:@r.ProgressPercent%"></div></div>
                                <small>@r.ProgressPercent%</small>
                            </div>
                        </td>
                        <td><span class="badge @sBadge">@r.StatusDisplay</span></td>
                        <td><small>@r.CreatedDate.ToString("d")</small></td>
                        <td><a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
