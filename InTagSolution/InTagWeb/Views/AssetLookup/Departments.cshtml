@model IEnumerable<InTagEntitiesLayer.Asset.Department>

<div class="content-header d-flex justify-content-between align-items-center">
    <h1><i class="bi bi-diagram-2 me-2"></i>Departments</h1>
    <a asp-action="CreateDepartment" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Department</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Parent</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No departments. <a asp-action="CreateDepartment">Create one</a>.</td></tr>
                }
                @foreach (var d in Model)
                {
                    <tr>
                        <td class="fw-bold">@(d.Code ?? "—")</td>
                        <td>@d.Name<br /><small class="text-muted">@d.Description</small></td>
                        <td><small class="text-muted">@(d.ParentDepartment?.Name ?? "—")</small></td>
                        <td><a asp-action="EditDepartment" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
